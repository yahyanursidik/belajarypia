VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Edge Function secrets for private Contabo S3-compatible storage.
# Set with: supabase secrets set S3_ENDPOINT=... S3_BUCKET=... etc.
S3_ENDPOINT=https://eu2.contabostorage.com
S3_REGION=us-east-1
S3_BUCKET=ypia-lms-private
S3_ACCESS_KEY_ID=your-contabo-access-key
S3_SECRET_ACCESS_KEY=your-contabo-secret-key
S3_SIGNED_URL_EXPIRES_SECONDS=900
